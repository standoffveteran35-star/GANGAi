{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PersonalOS Update",
  "type": "object",
  "properties": {
    "summary": {
      "type": "string"
    },
    "user_updates": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "category": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "confidence": {
            "type": "number"
          }
        },
        "required": [
          "category",
          "content",
          "confidence"
        ]
      }
    },
    "project_updates": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string",
            "enum": [
              "add",
              "update",
              "pause",
              "complete"
            ]
          },
          "project_name": {
            "type": "string"
          },
          "details": {
            "type": "string"
          },
          "confidence": {
            "type": "number"
          }
        },
        "required": [
          "action",
          "project_name",
          "confidence"
        ]
      }
    },
    "decision_updates": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "decision": {
            "type": "string"
          },
          "reasoning": {
            "type": "string"
          },
          "confidence": {
            "type": "number"
          }
        },
        "required": [
          "decision",
          "confidence"
        ]
      }
    },
    "lesson_updates": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "lesson": {
            "type": "string"
          },
          "evidence": {
            "type": "string"
          },
          "confidence": {
            "type": "number"
          }
        },
        "required": [
          "lesson",
          "confidence"
        ]
      }
    },
    "memory_updates": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string"
          },
          "event": {
            "type": "string"
          },
          "importance": {
            "type": "string"
          }
        },
        "required": [
          "event"
        ]
      }
    }
  }
}
